<Window
    x:Class="FolderOpenerGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FolderOpenerGUI"
    mc:Ignorable="d"
    Title="Folder Opener, but its a GUI!" Height="450" Width="800">
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="187*"/>
        </Grid.RowDefinitions>
        <!--
        so this is a grid, and we put things on grids
        seems nice, but first, we need to create definitions first.
        -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- now i can do things, i suppose -->
        <!-- Subtitle -->
        <TextBlock
            Name="lblSubtitle"
            Text="Categories"
            HorizontalAlignment="Center"
            FontFamily="Cascadia Code"
            FontSize="40"
            Foreground="White" Width="234"/>
        <!-- Previeew -->
        <TextBlock
            Name="lblPreview"
            Text="Paths"
            Grid.Column="1"
            FontSize="40"
            HorizontalAlignment="Center"
            FontFamily="Cascadia Code"
            Foreground="White" Width="118"/>

        <!-- CategoryList -->
        <ListView
            Name="categoryList"
            Background="#1c1c1c"
            Foreground="White"
            FontFamily="Cascadia Code"
            FontSize="15"
            Grid.Row="1"
            BorderBrush="White"
            SelectionChanged="categoryList_SelectionChanged"/>
        <!-- PathList -->
        <ListView
            Name="pathList"
            Background="#2c2c2c"
            Foreground="White"
            FontFamily="Cascadia Code"
            FontSize="15"
            Grid.Row="1"
            Grid.Column="1"
            BorderBrush="White"
            SelectionChanged="pathList_SelectionChanged"/>
    </Grid>
</Window>
